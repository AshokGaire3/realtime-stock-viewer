# --- Upstream market data providers (kept server-side; never shipped to the browser) ---
# Alpha Vantage: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here
# Finnhub (backup stock quotes): https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_api_key_here

# --- Claude API for the AI tutor & indicator explainers ---
# https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Optional model override (defaults to claude-opus-4-8). Use claude-sonnet-5 or
# claude-haiku-4-5 for cheaper/faster high-volume chat.
ANTHROPIC_MODEL=claude-opus-4-8

# --- Persistence ---
DATABASE_URL=sqlite:///./stockviewer.db

# --- CORS: comma-separated origins allowed to call the API (frontend dev + prod) ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
